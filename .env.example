# ════════════════════════════════════════════════════════════════════
# QRTagsPro — Configuration d'environnement pour Coolify
# ════════════════════════════════════════════════════════════════════
# Copiez ces variables dans Coolify → Environment Variables

# ─── Core ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Base de données SQLite (chemin dans le container Coolify)
# Le volume persistant doit être mappé sur /app/data
DATABASE_URL=file:/app/data/qrtags.db

# URL publique (adapter au domaine Coolify)
NEXT_PUBLIC_BASE_URL=https://votre-domaine.com
NEXT_PUBLIC_APP_URL=https://votre-domaine.com
NEXTAUTH_URL=https://votre-domaine.com

# Secrets (générer avec : openssl rand -base64 32)
NEXTAUTH_SECRET=generer-une-chaine-aleatoire-32-caracteres-min
ENCRYPTION_KEY=generer-une-chaine-aleatoire-32-caracteres-min

# ─── Superadmin par défaut ──────────────────────────────────────────
# Le superadmin est créé automatiquement au 1er démarrage:
#   Email: admin@qrtags.com
#   Mot de passe: admin123
# ⚠️ Changez le mot de passe après la 1ère connexion !
ADMIN_EMAIL=admin@qrtags.com
ADMIN_PASSWORD=admin123

# ─── Cron auto-checkout ────────────────────────────────────────────
# Secret pour le cron qui expire les QR dont la departureDate est dépassée.
# À appeler toutes les heures via Coolify Scheduled Tasks:
#   curl -X POST https://votre-domaine.com/api/cron/auto-checkout \
#     -H "Authorization: Bearer ${CRON_SECRET}"
CRON_SECRET=generer-une-chaine-aleatoire

# ─── Backup DB (optionnel) ─────────────────────────────────────────
CRON_BACKUP_ENABLED=true
CRON_BACKUP_SECRET=generer-une-chaine-aleatoire
