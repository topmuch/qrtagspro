# ════════════════════════════════════════════════════════════════════
# QRTags — Configuration d'environnement (exemple)
# Copiez ce fichier en .env et adaptez les valeurs.
# ════════════════════════════════════════════════════════════════════

# ─── Core ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Base de données SQLite (chemin absolu dans le container)
# En production Coolify, ce chemin est mappé sur un volume persistant.
DATABASE_URL=file:/app/data/qrtags.db

# URLs publiques (adapter au domaine Coolify)
NEXT_PUBLIC_BASE_URL=https://qrtags.votre-domaine.com
NEXT_PUBLIC_APP_URL=https://qrtags.votre-domaine.com
NEXTAUTH_URL=https://qrtags.votre-domaine.com

# Secrets (générer avec : openssl rand -base64 32)
NEXTAUTH_SECRET=changer-par-une-chaine-aleatoire-32-caracteres-mini
ENCRYPTION_KEY=changer-par-une-chaine-aleatoire-32-caracteres-mini

# ─── Compte Superadmin par défaut ───────────────────────────────────
# Créé au 1er démarrage si la DB est vide (voir scripts/create-admin.cjs)
ADMIN_EMAIL=admin@qrtags.com
ADMIN_PASSWORD=changer-ce-mot-de-passe-en-production

# ─── Notifications ──────────────────────────────────────────────────
# QRTags v1 : SEUL WhatsApp WAME (click-to-chat) est autorisé.
# Email, SMS et WhatsApp Business API sont désactivés (voir src/lib/notifications.ts).
# Pas de configuration nécessaire pour WAME — il utilise https://wa.me/[num]

# ─── Feature flags ──────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_MULTILINGUAL=true

# ─── Cron jobs ──────────────────────────────────────────────────────
CRON_BACKUP_ENABLED=true
CRON_BACKUP_SECRET=changer-par-une-chaine-aleatoire

# ─── Optionnel : AI (Groq) ──────────────────────────────────────────
# Si fourni, active la traduction IA et la détection de fraude sur les scans.
# Si vide, fallbacks classiques (règles métier) sont utilisés.
GROQ_API_KEY=

# ─── Optionnel : AviationStack (suivi de vols) ──────────────────────
# Pour l'alerte "vol de correspondance manquée" (Feature #5 QRBags).
# Non requis pour QRTags core.
AVIATIONSTACK_API_KEY=

# ─── Optionnel : Web Push (PWA) ─────────────────────────────────────
# Pour activer les notifications push browser (pas de SMS/Email).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@qrtags.com

# ─── Optionnel : PayPal (paiement tags) ─────────────────────────────
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
